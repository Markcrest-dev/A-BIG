rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Restricts actions to the designated admin email
    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == 'okafoamaka@gmail.com';
    }

    // 1. User Profiles Rules
    match /profiles/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 2. Orders Rules
    match /orders/{orderId} {
      // Authenticated users can place orders. 
      // Customers can view only their own order histories; admins can manage all orders.
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // 3. Products Catalog Rules
    match /products/{productId} {
      // Anyone can browse products (public read access)
      // Only your admin address can write, edit, or delete items
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Product Requests Rules (Restock & Custom Scent Requests)
    match /product_requests/{requestId} {
      // Anyone can submit restock/custom requests
      allow create: if true;
      // Only admins can view and manage requests
      allow read, update, delete: if isAdmin();
    }

    // 5. Notifications Rules
    match /notifications/{notificationId} {
      // Anyone can trigger a notification
      allow create: if true;
      // Customers can read and update their own notifications; admins can access all
      allow read, update: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin'));
      allow delete: if isAdmin();
    }
  }
}
